        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "# --- 1. PREPARAÇÃO DOS DADOS ---\n",
        "# Criamos 20 exemplos de casas (Área entre 30m2 e 150m2)\n",
        "np.random.seed(42)\n",
        "area = np.linspace(30, 150, 20).reshape(-1, 1)\n",
        "\n",
        "# O preço é calculado com uma base de R$ 75.000 + R$ 2.680 por m2 + um erro aleatório\n",
        "preco = 75000 + (area * 2680) + np.random.normal(0, 20000, size=area.shape)\n",
        "\n",
        "# --- 2. CRIAÇÃO E TREINAMENTO DO MODELO ---\n",
        "modelo = LinearRegression()\n",
        "modelo.fit(area, preco) # A IA estuda os dados aqui\n",
        "\n",
        "# --- 3. REALIZANDO UMA PREVISÃO ---\n",
        "# Vamos perguntar o preço de uma casa de 100m2 que a IA não viu\n",
        "area_nova = [[100]]\n",
        "preco_estimado = modelo.predict(area_nova)\n",
        "print(f\"Para uma casa de 100m², a IA prevê o preço de: R$ {preco_estimado[0][0]:.2f}\")\n",
        "\n",
        "# --- 4. VISUALIZAÇÃO DOS RESULTADOS ---\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.scatter(area, preco, color='blue', label='Casas Reais (Dados)')\n",
        "plt.plot(area, modelo.predict(area), color='red', linewidth=2, label='Previsão da IA')\n",
        "plt.title('Modelo de IA: Previsão de Preço por Área')\n",
        "plt.xlabel('Área (m²)')\n",
        "plt.ylabel('Preço (R$)')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()"
      ]
